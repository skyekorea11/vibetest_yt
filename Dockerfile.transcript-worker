FROM node:20-bookworm-slim

WORKDIR /app

# yt-dlp runtime dependencies
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 python3-pip ca-certificates ffmpeg \
  && rm -rf /var/lib/apt/lists/* \
  && pip3 install --no-cache-dir -U yt-dlp

COPY package*.json ./
RUN npm ci

COPY . .

ENV NODE_ENV=production
ENV YT_DLP_PATH=yt-dlp
ENV YT_DLP_USE_BROWSER_COOKIES=false
ENV TRANSCRIPT_SYNC_LIMIT=20

CMD ["npm", "run", "transcripts:sync"]
